[ivr]

exten => s,1,Answer()
same => n,Wait(0.3)
same => n,Set(TIMEOUT(digit)=3)
same => n,Set(TIMEOUT(response)=8)
same => n,Set(RETRY=0)
same => n,Goto(start,1)
;same => n(start),Background(custom/menuvoice)
;same => n,WaitExten()

; VALID with existence check
exten => _1XX,1,NoOp(User entered ${EXTEN})
same => n,GotoIf($[${DIALPLAN_EXISTS(internal,${EXTEN},1)}]?valid:invalid)
same => n(valid),Goto(internal,${EXTEN},1)
same => n(invalid),Goto(ivr,i,1)

exten => start,1,NoOp(IVR Restart)
 same => n,Background(custom/menuvoice)
 same => n,Read(dummy,,5,,1,1)
 same => n,WaitExten()


; INVALID catch
exten => _X,1,Goto(ivr,i,1)
exten => _X.,1,Goto(ivr,i,1)

; INVALID handler
exten => i,1,NoOp(Invalid input)
same => n,Set(RETRY=$[${RETRY}+1])
; same => GotoIf($[${RETRY}>=3]?ivr,fail,1) --- change
same => n,GotoIf($[${RETRY}>=3]?ivr,fail,1)
same => n,Playback(pbx-invalid)
same => n,Wait(0.5)
same => n,Read(dummy,,5,,1,1)
;same => n,Goto(ivr,start,1)
same => n,Goto(start,1)

; TIMEOUT handler
exten => t,1,NoOp(Timeout)
same => n,Set(RETRY=$[${RETRY}+1])
same => n,GotoIf($[${RETRY}>=3]?ivr,fail,1)
same => n,Playback(pbx-noinput)
same => n,Wait(0.5)
;same => n,Read(dummy,,5,,1,1)
same => n,Goto(ivr,start,1)

; FAIL
exten => fail,1,Playback(vm-goodbye)
same => n,Hangup()




[outbound-status]
exten => BUSY,1,Playtones(busy)
 same => n,Wait(3)
 same => n,Hangup()

exten => CONGESTION,1,Playtones(congestion)
 same => n,Wait(3)
 same => n,Hangup()

exten => _X.,1,Hangup() ; Catch-all for any other status

